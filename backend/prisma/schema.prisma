generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String   @unique
  username     String   @unique
  password_hash String
  full_name    String?
  avatar_url   String?
  bio          String?
  role         String   @default("contributor")
  is_active    Boolean  @default(true)
  last_login   DateTime?
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())

  reviews          Review[]
  comments         Comment[]
  notifications    Notification[]
  sessions         Session[]
  analyticsEvents  AnalyticsEvent[]
  githubConfigs    GithubConfig[]
  costEvents       CostEvent[]
  codeOwnerships   CodeOwnership[]
}

model Repository {
  id        String   @id
  name      String
  owner_id  String
  org_id    String?
  github_url String?
  primary_language String?
  description String?
  created_at DateTime @default(now())

  reviews Review[]
  rules   ReviewRule[]
}

model Review {
  id              String   @id
  repo_id         String
  title           String
  description     String?
  author_id       String
  status          String   @default("draft")
  branch_name     String
  base_branch     String   @default("main")
  files_changed   Int      @default(0)
  additions       Int      @default(0)
  deletions       Int      @default(0)
  ai_score        Float?
  complexity_score Float?
  priority        String   @default("medium")
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())
  merged_at       DateTime?

  repository Repository @relation(fields: [repo_id], references: [id])
  author     User       @relation(fields: [author_id], references: [id])
  issues     Issue[]
  comments   Comment[]
  codeFiles  CodeFile[]
  fixSuggestions FixSuggestion[]
  costEvents    CostEvent[]
}

model CodeFile {
  id        String @id
  review_id String
  name      String
  content   String

  review Review @relation(fields: [review_id], references: [id], onDelete: Cascade)
}

model Issue {
  id          String   @id
  review_id   String
  issue_type  String
  severity    String
  file_path   String?
  line_number Int?
  description String
  suggestion  String?
  ai_generated Boolean @default(false)
  status      String   @default("open")
  created_at  DateTime @default(now())

  review Review @relation(fields: [review_id], references: [id], onDelete: Cascade)
  fixSuggestions FixSuggestion[]
}

model Comment {
  id              String   @id
  review_id       String
  author_id       String
  file_path       String?
  line_number     Int?
  content         String
  is_suggestion   Boolean  @default(false)
  suggestion_text String?
  thread_id       String?
  resolved        Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())

  review Review @relation(fields: [review_id], references: [id], onDelete: Cascade)
  author User   @relation(fields: [author_id], references: [id])
}

model Notification {
  id         String   @id
  user_id    String
  type       String
  title      String
  content    String?
  review_id  String?
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
}

model Session {
  id           String   @id
  name         String?
  creator_id   String
  status       String   @default("active")
  code         String?
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())

  creator      User              @relation(fields: [creator_id], references: [id])
  participants SessionParticipant[]
}

model SessionParticipant {
  id        String @id
  session_id String
  user_id   String

  session Session @relation(fields: [session_id], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id        String   @id
  user_id   String?
  team_id   String?
  date      DateTime @default(now())
  event_type String
  metadata  String?

  user User? @relation(fields: [user_id], references: [id])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model GithubConfig {
  id                String   @id @default(cuid())
  user_id           String
  repo_owner        String
  repo_name         String
  repo_full_name    String
  github_repo_id    Int?
  webhook_secret    String
  access_token      String
  is_active         Boolean  @default(true)
  auto_review       Boolean  @default(true)
  default_persona   String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user        User          @relation(fields: [user_id], references: [id])
  webhookLogs WebhookLog[]
}

model WebhookLog {
  id               String   @id @default(cuid())
  github_config_id String
  event_type       String
  action           String
  pr_number        Int
  pr_title         String?
  status           String   @default("received")
  error_message    String?
  payload          String?
  created_at       DateTime @default(now())

  githubConfig GithubConfig @relation(fields: [github_config_id], references: [id])
}

model FixSuggestion {
  id            String   @id @default(cuid())
  issue_id      String
  review_id     String
  original_code String
  fixed_code    String
  explanation   String
  status        String   @default("pending")
  applied_at    DateTime?
  created_at    DateTime @default(now())

  issue  Issue  @relation(fields: [issue_id], references: [id])
  review Review @relation(fields: [review_id], references: [id])
}

model ReviewRule {
  id         String   @id @default(cuid())
  repo_id    String
  name       String
  type       String
  pattern    String?
  max_value  Int?
  forbidden  String?
  require    String?
  severity   String   @default("warning")
  message    String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  repository Repository @relation(fields: [repo_id], references: [id])
}

model CostEvent {
  id            String   @id @default(cuid())
  user_id       String
  review_id     String?
  model         String
  input_tokens  Int
  output_tokens Int
  cost_cents    Int
  duration_ms   Int?
  status        String   @default("success")
  created_at    DateTime @default(now())

  user   User    @relation(fields: [user_id], references: [id])
  review Review? @relation(fields: [review_id], references: [id])
}

model QualitySnapshot {
  id                String   @id @default(cuid())
  team_id           String
  period_start      DateTime
  period_end        DateTime
  avg_score         Float?
  issues_per_review Float?
  resolution_rate   Float?
  critical_rate     Float?
  review_count      Int      @default(0)
  issue_count       Int      @default(0)
  resolved_count    Int      @default(0)
  created_at        DateTime @default(now())
}

model FileDependency {
  id          String   @id @default(cuid())
  repo_id     String
  file_path   String
  imports     String
  imported_by String
  language    String?
  updated_at  DateTime @updatedAt

  @@unique([repo_id, file_path])
}

model ReviewPersona {
  id            String   @id @default(cuid())
  name          String   @unique
  display_name  String
  description   String?
  system_prompt String
  tone          String
  icon          String?
  is_custom     Boolean  @default(false)
  user_id       String?
  created_at    DateTime @default(now())
}

model CodeOwnership {
  id              String   @id @default(cuid())
  user_id         String
  repo_id         String
  file_pattern    String
  review_count    Int      @default(0)
  last_reviewed   DateTime?
  expertise_score Float    @default(0)

  user User @relation(fields: [user_id], references: [id])

  @@unique([user_id, repo_id, file_pattern])
}
